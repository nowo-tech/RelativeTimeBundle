{
    "name": "nowo-tech/relative-time-bundle",
    "description": "Format DateTime values as localized relative time strings (e.g. just now, 5 minutes ago) for Symfony and Twig.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "relative-time",
        "time-ago",
        "datetime",
        "i18n",
        "twig",
        "translation"
    ],
    "homepage": "https://github.com/nowo-tech/RelativeTimeBundle",
    "support": {
        "issues": "https://github.com/nowo-tech/RelativeTimeBundle/issues",
        "source": "https://github.com/nowo-tech/RelativeTimeBundle",
        "docs": "https://github.com/nowo-tech/RelativeTimeBundle/tree/main/docs",
        "changelog": "https://github.com/nowo-tech/RelativeTimeBundle/blob/main/docs/CHANGELOG.md"
    },
    "authors": [
        {
            "name": "H\u00e9ctor Franco Aceituno",
            "email": "hectorfranco@nowo.tech",
            "homepage": "https://github.com/HecFranco",
            "role": "Developer"
        },
        {
            "name": "Nowo.tech",
            "homepage": "https://nowo.tech"
        }
    ],
    "require": {
        "php": ">=8.2 <8.6",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "symfony/translation": "^7.4 || ^8.0",
        "symfony/translation-contracts": "^3.0",
        "twig/twig": "^3.8 || ^4.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.0",
        "rector/rector": "^2.0",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/yaml": "^7.4 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Nowo\\RelativeTimeBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nowo\\RelativeTimeBundle\\Tests\\": "tests/"
        }
    },
    "archive": {
        "exclude": [
            "/demo",
            "/.cursor"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit --colors=always",
        "test-unit": "phpunit --testsuite=Unit",
        "test-integration": "phpunit --testsuite=Integration",
        "test-coverage": "phpunit --colors=always --coverage-html coverage --coverage-clover coverage.xml --coverage-text",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process",
        "rector-dry": "rector process --dry-run --no-progress-bar",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "update": "composer update --no-interaction",
        "validate": "composer validate --strict",
        "qa": [
            "@cs-check",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit tests",
        "test-unit": "Run Unit tests only",
        "test-integration": "Run Integration tests only",
        "test-coverage": "Run PHPUnit tests with code coverage",
        "cs-check": "Check code style with PHP-CS-Fixer",
        "cs-fix": "Fix code style with PHP-CS-Fixer",
        "rector": "Apply Rector refactoring",
        "rector-dry": "Run Rector in dry-run mode",
        "phpstan": "Run PHPStan static analysis",
        "update": "Update composer.lock (composer update)",
        "validate": "Validate composer.json (composer validate --strict)",
        "qa": "Run all quality assurance checks"
    },
    "suggest": {
        "symfony/flex": "For automatic recipe installation",
        "symfony/twig-bundle": "To use the Twig filters and functions in a Symfony application"
    }
}
